<view class="container">
  <view class="audio-card">
    <text class="title">{{title}}</text>
    
    <view class="progress-container">
      <text class="time">{{currentTime}}</text>
      <slider class="progress" value="{{progress}}" block-size="12" activeColor="#07c160" />
      <text class="time">{{duration}}</text>
    </view>
    
    <view class="controls">
      <view class="btn-play" bindtap="togglePlay">
        <text>{{isPlaying ? '暂停' : '播放'}}</text>
      </view>
    </view>
  </view>
</view>